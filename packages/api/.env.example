# Database
DATABASE_URL="postgresql://atlas:atlas@localhost:5432/atlas_dev?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Object Storage (MinIO in dev)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=atlas-storage
S3_REGION=us-east-1

# Email (MS Graph)
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_MAILBOX=collateral-ai@example.com

# LLM
LLM_MODE=ON
LLM_PROVIDER=azure-openai
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=

# Auth
OIDC_ISSUER=http://localhost:8080/realms/atlas
OIDC_CLIENT_ID=atlas-api
OIDC_CLIENT_SECRET=

# App
PORT=3000
NODE_ENV=development
